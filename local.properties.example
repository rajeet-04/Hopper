# ============================================================
# Hopper - local.properties template
# ============================================================
# Copy this file to `local.properties` and fill in your values.
# local.properties is gitignored and will NOT be committed.
# ============================================================

# Android SDK location
sdk.dir=/path/to/your/Android/Sdk

# Backend API (your deployed Cloudflare Worker URL)
api.base.url=https://hopper-api.your-subdomain.workers.dev/

# MapLibre Style URLs (replace with your own tile server if needed)
map.style.url=https://demotiles.maplibre.org/style.json
map.night.style.url=https://demotiles.maplibre.org/style.json
map.tiles.url=https://demotiles.maplibre.org/tiles/tiles.json
